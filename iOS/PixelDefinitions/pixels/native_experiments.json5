{
    // This file defines pixels sent by the native experiments framework
    "defaultSuffixes": [],
    "activeExperiments": {
        "autofillOnboardingExperiment": {
            "cohorts": ["control", "variant1", "variant2", "variant3"],
            "metrics": {
                "save_tap": {
                    "description": "Fires once per user when they tap Save on the autofill onboarding prompt",
                    "enum": ["1"]
                },
                "dismiss_tap": {
                    "description": "Fires each time the user dismisses the autofill onboarding prompt",
                    "enum": ["1"]
                },
                "never_ask_tap": {
                    "description": "Fires at various thresholds when the user taps Never ask for this site",
                    "enum": ["1", "2", "3", "5"]
                },
                "passwords_saved": {
                    "description": "Fires on each password save with the current account count bucket",
                    "enum": ["none", "few", "some", "many", "lots"]
                },
                "import_completed": {
                    "description": "Fires when the user completes the data import flow",
                    "enum": ["1"]
                },
                "autofill_enabled": {
                    "description": "Fires when the user enables or disables autofill",
                    "type": "boolean"
                },
                "sync_enabled": {
                    "description": "Fires when the user enables or disables sync",
                    "type": "boolean"
                },
                "autofill_other_apps_enabled": {
                    "description": "Fires when the user enables or disables Autofill in Other Apps (autofill provider extension)",
                    "type": "boolean"
                },
                "impression_count": {
                    "description": "Bucketed number of onboarding prompt impressions before the user saved",
                    "enum": ["1", "2-3", "4-6", "7-10", "11+"]
                },
                "days_to_conversion": {
                    "description": "Bucketed number of days between experiment enrollment and first save",
                    "enum": ["0", "1", "2-3", "4-5", "6-7", "8+"]
                }
            }
        }
    }
}
