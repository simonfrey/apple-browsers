            {
                "key": "feature.data.ext.scan.free_scan",
                "type": "string",
                "description": "Whether this scan attempt belongs to a free (unauthenticated) user",
                "enum": ["true", "false"]
            },
            {
                "key": "feature.data.ext.scan.latency_ms",
                "type": "string",
                "description": "Duration in milliseconds between the scan attempt start and completion"
            }
        ]
