{
    "m_web_extension_installed": {
        "description": "Fires when a web extension is successfully installed.",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": ["appVersion"]
    },
    "m_web_extension_install_error": {
        "description": "Fires when a web extension installation fails.",
        "owners": ["tomasstrba"],
        "triggers": ["exception"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": ["appVersion", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    },
    "m_web_extension_uninstalled": {
        "description": "Fires when a web extension is successfully uninstalled.",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": ["appVersion"]
    },
    "m_web_extension_uninstall_error": {
        "description": "Fires when a web extension uninstallation fails.",
        "owners": ["tomasstrba"],
        "triggers": ["exception"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": ["appVersion", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    },
    "m_web_extension_uninstalled_all": {
        "description": "Fires when all web extensions are successfully uninstalled.",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": ["appVersion"]
    },
    "m_web_extension_uninstall_all_error": {
        "description": "Fires when uninstalling all web extensions fails (at least one extension failed to uninstall).",
        "owners": ["tomasstrba"],
        "triggers": ["exception"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": ["appVersion", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    },
    "m_web_extension_loaded": {
        "description": "Fires during app startup when installed web extensions are successfully loaded.",
        "owners": ["tomasstrba"],
        "triggers": ["other"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": ["appVersion"]
    },
    "m_web_extension_load_error": {
        "description": "Fires during app startup when loading installed web extensions fails (at least one extension failed to load).",
        "owners": ["tomasstrba"],
        "triggers": ["exception"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": ["appVersion", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    },
    "m_web_extension_embedded_installed": {
        "description": "Fires when the embedded (bundled) web extension is successfully installed for the first time.",
        "owners": ["tomasstrba", "miasma13"],
        "triggers": ["other"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": ["appVersion"]
    },
    "m_web_extension_embedded_upgraded": {
        "description": "Fires when the embedded (bundled) web extension is upgraded to a newer version.",
        "owners": ["tomasstrba", "miasma13"],
        "triggers": ["other"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": [
            "appVersion",
            {
                "key": "from_version",
                "type": "string",
                "description": "The previous version of the embedded extension before upgrade"
            },
            {
                "key": "to_version",
                "type": "string",
                "description": "The new version of the embedded extension after upgrade"
            }
        ]
    },
    "m_web_extension_embedded_install_error": {
        "description": "Fires when installing or upgrading the embedded (bundled) web extension fails.",
        "owners": ["tomasstrba", "miasma13"],
        "triggers": ["exception"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": ["appVersion", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    },
    "m_web_extension_dark_reader_installed": {
        "description": "Fires when the embedded (bundled) Dark Reader extension is successfully installed for the first time.",
        "owners": ["dus7"],
        "triggers": ["other"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": ["appVersion"]
    },
    "m_web_extension_dark_reader_upgraded": {
        "description": "Fires when the embedded (bundled) Dark Reader extension is upgraded to a newer version.",
        "owners": ["dus7"],
        "triggers": ["other"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": [
            "appVersion",
            {
                "key": "from_version",
                "type": "string",
                "description": "The previous version of the embedded Dark Reader extension before upgrade"
            },
            {
                "key": "to_version",
                "type": "string",
                "description": "The new version of the embedded Dark Reader extension after upgrade"
            }
        ]
    },
    "m_web_extension_dark_reader_install_error": {
        "description": "Fires when installing or upgrading the embedded (bundled) Dark Reader extension fails.",
        "owners": ["dus7"],
        "triggers": ["exception"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": ["appVersion", "errorCode", "errorDomain", "underlyingErrorCode", "underlyingErrorDomain"]
    },
    "m_web_extension_dark_reader_enabled": {
        "description": "Fires when the user enables the Dark Reader extension in settings.",
        "owners": ["dus7"],
        "triggers": ["other"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": ["appVersion"]
    },
    "m_web_extension_dark_reader_disabled": {
        "description": "Fires when the user disables the Dark Reader extension in settings.",
        "owners": ["dus7"],
        "triggers": ["other"],
        "suffixes": [
            ["daily", "platform", "form_factor"],
            ["platform", "form_factor"]
        ],
        "parameters": ["appVersion"]
    }
}
