{
    "sync-auto-restore_onboarding_prompt_shown_unique": {
        "description": "Fired when the onboarding auto-restore prompt is shown to an eligible returning user",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "sync-auto-restore_onboarding_restore_tapped_unique": {
        "description": "Fired when the user taps Restore My Data on the onboarding auto-restore prompt",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "sync-auto-restore_onboarding_skip_tapped_unique": {
        "description": "Fired when the user taps Skip Restore on the onboarding auto-restore prompt",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "sync-auto-restore_toggle_shown": {
        "description": "Fired when the Save Recovery Key view is shown with the auto-restore toggle visible",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "sync-auto-restore_toggle_opted_out": {
        "description": "Fired when the user taps Next on Save Recovery Key while auto-restore is OFF",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "sync-auto-restore_settings_ready_shown": {
        "description": "Fired when the Auto Restore Ready view is displayed in Sync settings",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": [
            "appVersion",
            {
                "key": "source",
                "type": "string",
                "description": "How the user entered the Auto Restore Ready prompt",
                "enum": ["sync_pairing", "sync_backup", "sync_recover"]
            }
        ]
    },
    "sync-auto-restore_settings_restore_tapped": {
        "description": "Fired when the user taps Restore My Data on the Auto Restore Ready view",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": [
            "appVersion",
            {
                "key": "source",
                "type": "string",
                "description": "How the user entered the Auto Restore Ready prompt",
                "enum": ["sync_pairing", "sync_backup", "sync_recover"]
            }
        ]
    },
    "sync-auto-restore_settings_skip_restore_tapped": {
        "description": "Fired when the user taps Skip Restore and continues with manual recovery or setup",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": [
            "appVersion",
            {
                "key": "source",
                "type": "string",
                "description": "How the user entered the Auto Restore Ready prompt",
                "enum": ["sync_pairing", "sync_backup", "sync_recover"]
            }
        ]
    },
    "sync-auto-restore_settings_cancelled": {
        "description": "Fired when the user cancels the Auto Restore Ready view",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": [
            "appVersion",
            {
                "key": "source",
                "type": "string",
                "description": "How the user entered the Auto Restore Ready prompt",
                "enum": ["sync_pairing", "sync_backup", "sync_recover"]
            }
        ]
    },
    "sync-auto-restore_settings_manual_recovery_shown": {
        "description": "Fired when the Recover Synced Data view is shown in the manual recovery fallback path",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "sync-auto-restore_settings_page_shown": {
        "description": "Fired when the Restore on App re-install settings page is shown",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "sync-auto-restore_settings_page_toggle_enabled": {
        "description": "Fired when auto-restore is enabled from the settings page after local authentication",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "sync-auto-restore_settings_page_toggle_disabled": {
        "description": "Fired when auto-restore is disabled from the settings page after local authentication",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": ["appVersion"]
    },
    "sync-auto-restore_success": {
        "description": "Fired when auto-restore completes successfully",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": [
            "appVersion",
            {
                "key": "source",
                "type": "string",
                "description": "Origin of the auto-restore flow",
                "enum": ["onboarding", "settings"]
            }
        ]
    },
    "sync-auto-restore_failure": {
        "description": "Fired when auto-restore fails",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": [
            "appVersion",
            {
                "key": "source",
                "type": "string",
                "description": "Origin of the auto-restore flow",
                "enum": ["onboarding", "settings"]
            },
            "errorCode",
            "errorDomain",
            "underlyingErrorCode",
            "underlyingErrorDomain"
        ]
    },
    "sync-auto-restore_preserved_account_cleared": {
        "description": "Fired when a preserved sync account is successfully removed before continuing a manual recovery or setup flow",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": [
            "appVersion",
            {
                "key": "source",
                "type": "string",
                "description": "How the user entered the preserved-account cleanup flow",
                "enum": ["sync_pairing", "sync_backup", "sync_recover"]
            }
        ]
    },
    "sync-auto-restore_preserved_account_clear_failed": {
        "description": "Fired when preserved sync account removal fails and the manual recovery or setup flow is blocked",
        "owners": ["amddg44"],
        "triggers": ["other"],
        "suffixes": ["platform", "form_factor"],
        "parameters": [
            "appVersion",
            {
                "key": "source",
                "type": "string",
                "description": "How the user entered the preserved-account cleanup flow",
                "enum": ["sync_pairing", "sync_backup", "sync_recover"]
            },
            "errorCode",
            "errorDomain",
            "underlyingErrorCode",
            "underlyingErrorDomain"
        ]
    }
}
