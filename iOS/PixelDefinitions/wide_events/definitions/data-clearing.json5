{
    // Defined in https://app.asana.com/1/137249556945/task/1212683300907458?focus=true
    "ios-data-clearing": {
        "description": "Wide pixel sent at the end of a data clearing flow on iOS",
        "owners": ["hanyutang-sandra"],
        "meta": {
            "type": "ios-data-clearing",
            "version": "0.0"
        },
        "feature": {
            "name": "data-clearing",
            "status": ["SUCCESS", "UNKNOWN"],
            "data": {
                "ext": {
                    "status_reason": {
                        "type": "string",
                        "description": "Reason for the current status",
                        "enum": ["partial_data", "timeout"]
                    },
                    "included_options": {
                        "type": "string",
                        "description": "Comma-separated list of specific options selected (tabs, data, aiChats) (iOS only)",
                        "enum": ["tabs", "data", "aiChats", "tabs,data", "tabs,aiChats", "data,aiChats", "tabs,data,aiChats"]
                    },
                    "trigger": {
                        "type": "string",
                        "description": "What initiated the clearing flow",
                        "enum": ["manualFire", "autoClearOnLaunch", "autoClearOnForeground"]
                    },
                    "scope": {
                        "type": "string",
                        "description": "Scope of the clearing action",
                        "enum": ["tab", "all"]
                    },
                    "source": {
                        "type": "string",
                        "description": "Entry point that triggered the data clearing flow",
                        "enum": ["browsing", "tabSwitcher", "settings", "quickFire", "deeplink", "autoClear"]
                    },
                    "overall_latency_ms": {
                        "type": "integer",
                        "description": "Duration from start of clearing attempt to end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                    },
                    // Per-action status - all 17 iOS actions
                    "(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_url_caches|clear_daxDialogs_held_URL_data|clear_website_data\\.remove_observations_data|clear_website_data\\.remove_all_containers_after_delay|delete_contextual_aiChat)_status": {
                        "type": "string",
                        "description": "Final status of each clearing action",
                        "enum": ["SUCCESS", "FAILURE"]
                    },
                    // Per-action latency - all 17 iOS actions
                    "(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_url_caches|clear_daxDialogs_held_URL_data|clear_website_data\\.remove_observations_data|clear_website_data\\.remove_all_containers_after_delay|delete_contextual_aiChat)_latency_ms": {
                        "type": "integer",
                        "description": "Duration from start of action to end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                    },
                    // Per-action error domains - all 17 iOS actions
                    "(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_url_caches|clear_daxDialogs_held_URL_data|clear_website_data\\.remove_observations_data|clear_website_data\\.remove_all_containers_after_delay|delete_contextual_aiChat)_error\\.domain": {
                        "type": "string",
                        "description": "Top level error domain for action failures",
                        "examples": ["DataClearingWideEventError", "NSCocoaErrorDomain", "com.duckduckgo.history"]
                    },
                    // Per-action error codes - all 17 iOS actions
                    "(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_url_caches|clear_daxDialogs_held_URL_data|clear_website_data\\.remove_observations_data|clear_website_data\\.remove_all_containers_after_delay|delete_contextual_aiChat)_error\\.code": {
                        "type": "integer",
                        "description": "Top level error code for action failures"
                    },
                    // Per-action error descriptions - all 17 iOS actions
                    "(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_url_caches|clear_daxDialogs_held_URL_data|clear_website_data\\.remove_observations_data|clear_website_data\\.remove_all_containers_after_delay|delete_contextual_aiChat)_error\\.description": {
                        "type": "string",
                        "description": "Human-readable error description for action failures",
                        "examples": [
                            "coordinatorNotInitialized",
                            "fileRemovalFailed",
                            "databaseSaveFailed",
                            "historyNotLoaded",
                            "directoryCreationFailed",
                            "fileMoveOperationFailed",
                            "databaseOpenFailed"
                        ]
                    },
                    // Per-action underlying error domains - all 17 iOS actions
                    "(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_url_caches|clear_daxDialogs_held_URL_data|clear_website_data\\.remove_observations_data|clear_website_data\\.remove_all_containers_after_delay|delete_contextual_aiChat)_error\\.underlying_domain": {
                        "type": "string",
                        "description": "Underlying error domain for action failures",
                        "examples": ["NSPOSIXErrorDomain", "NSURLErrorDomain", "SQLite.Result"]
                    },
                    // Per-action underlying error codes - all 17 iOS actions
                    "(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_url_caches|clear_daxDialogs_held_URL_data|clear_website_data\\.remove_observations_data|clear_website_data\\.remove_all_containers_after_delay|delete_contextual_aiChat)_error\\.underlying_code": {
                        "type": "integer",
                        "description": "Underlying error code for action failures"
                    }
                }
            }
        }
    }
}
