{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Wide pixel sent at the end of a data clearing flow on iOS",
    "$comment": "{\"owners\":[\"hanyutang-sandra\"]}",
    "type": "object",
    "required": ["meta", "global", "feature", "app"],
    "additionalProperties": false,
    "properties": {
        "meta": {
            "type": "object",
            "required": ["type", "version"],
            "additionalProperties": false,
            "properties": { "type": { "const": "ios-data-clearing" }, "version": { "const": "1.0.1" } }
        },
        "app": {
            "type": "object",
            "required": ["name", "version", "form_factor"],
            "additionalProperties": false,
            "properties": {
                "name": {
                    "type": "string",
                    "description": "The name of the application",
                    "enum": ["DuckDuckGo", "DuckDuckGo-Alpha", "DuckDuckGo-Experimental"]
                },
                "version": { "type": "string", "description": "The version of the application", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
                "form_factor": { "type": "string", "description": "The form factor of the device", "enum": ["phone", "tablet"] }
            }
        },
        "global": {
            "type": "object",
            "required": ["platform", "type", "sample_rate", "is_first_daily_occurrence"],
            "additionalProperties": false,
            "properties": {
                "platform": { "type": "string", "description": "The platform the app is running on", "enum": ["iOS"] },
                "type": { "type": "string", "description": "The type of application", "enum": ["app"] },
                "sample_rate": { "type": "number", "description": "Sample rate for this event", "minimum": 0, "maximum": 1 },
                "is_first_daily_occurrence": {
                    "type": "boolean",
                    "description": "Whether this is the first occurrence of this event today. Only included when true."
                }
            }
        },
        "feature": {
            "type": "object",
            "required": ["name", "status", "data"],
            "additionalProperties": false,
            "properties": {
                "name": { "type": "string", "description": "The feature name for this event", "enum": ["data-clearing"] },
                "status": { "type": "string", "description": "The overall status of the operation", "enum": ["SUCCESS", "UNKNOWN"] },
                "data": {
                    "type": "object",
                    "required": ["ext"],
                    "additionalProperties": false,
                    "properties": {
                        "ext": {
                            "type": "object",
                            "additionalProperties": false,
                            "properties": {
                                "status_reason": {
                                    "type": "string",
                                    "description": "Reason for the current status",
                                    "enum": ["partial_data", "timeout"]
                                },
                                "included_options": {
                                    "type": "string",
                                    "description": "Comma-separated list of specific options selected (tabs, data, aiChats) (iOS only)",
                                    "enum": ["tabs", "data", "aiChats", "tabs,data", "tabs,aiChats", "data,aiChats", "tabs,data,aiChats"]
                                },
                                "trigger": {
                                    "type": "string",
                                    "description": "What initiated the clearing flow",
                                    "enum": ["manualFire", "autoClearOnLaunch", "autoClearOnForeground", "fireModeAutoClear"]
                                },
                                "scope": {
                                    "type": "string",
                                    "description": "Scope of the clearing action",
                                    "enum": ["tab", "fireMode", "normalMode", "all"]
                                },
                                "source": {
                                    "type": "string",
                                    "description": "Entry point that triggered the data clearing flow",
                                    "enum": ["browsing", "tabSwitcher", "settings", "quickFire", "deeplink", "autoClear"]
                                },
                                "overall_latency_ms": {
                                    "type": "integer",
                                    "description": "Duration from start of clearing attempt to end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                                },
                                "(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_url_caches|clear_daxDialogs_held_URL_data|clear_website_data\\.remove_observations_data|clear_website_data\\.remove_all_containers_after_delay|delete_contextual_aiChat|clear_website_data_fire_mode|clear_autoconsent_management_cache_fire_mode|forget_text_zoom_fire_mode)_status": {
                                    "type": "string",
                                    "description": "Final status of each clearing action",
                                    "enum": ["SUCCESS", "FAILURE"]
                                },
                                "(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_url_caches|clear_daxDialogs_held_URL_data|clear_website_data\\.remove_observations_data|clear_website_data\\.remove_all_containers_after_delay|delete_contextual_aiChat|clear_website_data_fire_mode|clear_autoconsent_management_cache_fire_mode|forget_text_zoom_fire_mode)_latency_ms": {
                                    "type": "integer",
                                    "description": "Duration from start of action to end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
                                },
                                "(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_url_caches|clear_daxDialogs_held_URL_data|clear_website_data\\.remove_observations_data|clear_website_data\\.remove_all_containers_after_delay|delete_contextual_aiChat|clear_website_data_fire_mode|clear_autoconsent_management_cache_fire_mode|forget_text_zoom_fire_mode)_error\\.domain": {
                                    "type": "string",
                                    "description": "Top level error domain for action failures",
                                    "examples": ["DataClearingWideEventError", "NSCocoaErrorDomain", "com.duckduckgo.history"]
                                },
                                "(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_url_caches|clear_daxDialogs_held_URL_data|clear_website_data\\.remove_observations_data|clear_website_data\\.remove_all_containers_after_delay|delete_contextual_aiChat|clear_website_data_fire_mode|clear_autoconsent_management_cache_fire_mode|forget_text_zoom_fire_mode)_error\\.code": {
                                    "type": "integer",
                                    "description": "Top level error code for action failures"
                                },
                                "(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_url_caches|clear_daxDialogs_held_URL_data|clear_website_data\\.remove_observations_data|clear_website_data\\.remove_all_containers_after_delay|delete_contextual_aiChat|clear_website_data_fire_mode|clear_autoconsent_management_cache_fire_mode|forget_text_zoom_fire_mode)_error\\.description": {
                                    "type": "string",
                                    "description": "Human-readable error description for action failures",
                                    "examples": [
                                        "coordinatorNotInitialized",
                                        "fileRemovalFailed",
                                        "databaseSaveFailed",
                                        "historyNotLoaded",
                                        "directoryCreationFailed",
                                        "fileMoveOperationFailed",
                                        "databaseOpenFailed"
                                    ]
                                },
                                "(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_url_caches|clear_daxDialogs_held_URL_data|clear_website_data\\.remove_observations_data|clear_website_data\\.remove_all_containers_after_delay|delete_contextual_aiChat|clear_website_data_fire_mode|clear_autoconsent_management_cache_fire_mode|forget_text_zoom_fire_mode)_error\\.underlying_domain": {
                                    "type": "string",
                                    "description": "Underlying error domain for action failures",
                                    "examples": ["NSPOSIXErrorDomain", "NSURLErrorDomain", "SQLite.Result"]
                                },
                                "(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_url_caches|clear_daxDialogs_held_URL_data|clear_website_data\\.remove_observations_data|clear_website_data\\.remove_all_containers_after_delay|delete_contextual_aiChat|clear_website_data_fire_mode|clear_autoconsent_management_cache_fire_mode|forget_text_zoom_fire_mode)_error\\.underlying_code": {
                                    "type": "integer",
                                    "description": "Underlying error code for action failures"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
