/* About page subscription sentence: rebranding + AI chat */
"settings.about.subscription.sentence.rebranding.ai" = "Dessutom erbjuder vi också [DuckDuckGo-abonnemanget](ddgQuickLink://duckduckgo.com/duckduckgo-help-pages/privacy-pro/) som är integrerad i vår webbläsare. Abonnenter får ännu mer integritetsskydd med ett snabbt och enkelt [VPN](ddgQuickLink://duckduckgo.com/duckduckgo-help-pages/privacy-pro/vpn/) som hjälper till att skydda din onlineaktivitet, tillgång till avancerade AI-modeller i den privata AI-chattjänsten Duck.ai, en tjänst som hittar och tar bort din personliga information från webbplatser som är till för att hitta människor, samt en tjänst som återställer din identitet om den skulle bli stulen.";

/* about tagline */
