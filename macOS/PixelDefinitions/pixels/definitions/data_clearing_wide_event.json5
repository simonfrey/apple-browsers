{
    // Defined in https://app.asana.com/1/137249556945/task/1212683300907458?focus=true
    "m_mac_wide_data_clearing": {
        "description": "Wide pixel sent at the end of a data clearing flow",
        "owners": ["hanyutang-sandra"],
        "triggers": ["other"],
        "suffixes": ["daily"],
        "parameters": [
            // Standard wide event parameters
            "appVersion",
            "wideEventAppName",
            "wideEventAppVersion",
            "wideEventPlatform",
            "wideEventType",
            "wideEventSampleRate",
            "wideEventIsFirstDailyOccurrence",
            "wideEventFeatureStatus",
            "wideEventErrorDomain",
            "wideEventErrorCode",
            "wideEventErrorDescription",
            "wideEventUnderlyingErrorDomain",
            "wideEventUnderlyingErrorCode",
            "wideEventMetaVersion",

            // Wide event type identifier
            {
                "key": "meta.type",
                "type": "string",
                "description": "Wide event type identifier",
                "enum": ["macos-data-clearing"]
            },

            // Feature identifier
            {
                "key": "feature.name",
                "type": "string",
                "description": "Feature identifier for this wide pixel",
                "enum": ["data-clearing"]
            },

            // Feature data
            {
                "key": "feature.data.ext.options",
                "type": "string",
                "description": "What data the user selected for clearing",
                "enum": ["currentTab", "currentWindow", "allData"]
            },
            {
                "key": "feature.data.ext.trigger",
                "type": "string",
                "description": "What initiated the clearing flow",
                "enum": ["manual", "autoClear"]
            },
            {
                "key": "feature.data.ext.path",
                "type": "string",
                "description": "Execution path during clearing",
                "enum": ["burnEntity", "burnAll", "burnVisits"]
            },
            {
                "key": "feature.data.ext.included_domains",
                "type": "string",
                "description": "Comma-separated list of domain categories included",
                "enum": [
                    "History",
                    "TabsAndWindows",
                    "History,TabsAndWindows",
                    "CookiesAndSiteData",
                    "History,CookiesAndSiteData",
                    "TabsAndWindows,CookiesAndSiteData",
                    "History,TabsAndWindows,CookiesAndSiteData",
                    "ChatHistory",
                    "History,ChatHistory",
                    "TabsAndWindows,ChatHistory",
                    "History,TabsAndWindows,ChatHistory",
                    "CookiesAndSiteData,ChatHistory",
                    "History,CookiesAndSiteData,ChatHistory",
                    "TabsAndWindows,CookiesAndSiteData,ChatHistory",
                    "History,TabsAndWindows,CookiesAndSiteData,ChatHistory"
                ]
            },
            {
                "key": "feature.data.ext.status_reason",
                "type": "string",
                "description": "Reason for the current status",
                "enum": ["partial_data", "timeout"]
            },

            // Overall latency
            {
                "key": "feature.data.ext.overall_latency_ms",
                "type": "integer",
                "description": "Duration from start of clearing attempt to end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
            },

            // Per-action status - all 22 actions
            {
                "keyPattern": "feature\\.data\\.ext\\.(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_permissions|clear_visited_links|clear_recently_closed|clear_last_session_state|reset_cookie_popup_blocked_flag|clear_autoconsent_stats|clear_visits|clear_website_data\\.clear_file_cache|clear_website_data\\.clear_device_hash_salts|clear_website_data\\.clear_remove_resource_load_statistics_database)_status",
                "type": "string",
                "description": "Final status of each clearing action",
                "enum": ["SUCCESS", "FAILURE"]
            },

            // Per-action latency - all 22 actions
            {
                "keyPattern": "feature\\.data\\.ext\\.(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_permissions|clear_visited_links|clear_recently_closed|clear_last_session_state|reset_cookie_popup_blocked_flag|clear_autoconsent_stats|clear_visits|clear_website_data\\.clear_file_cache|clear_website_data\\.clear_device_hash_salts|clear_website_data\\.clear_remove_resource_load_statistics_database)_latency_ms",
                "type": "integer",
                "description": "Duration from start of action to end state (in ms). Rounded to 10ms precision, capped at 10000ms (10 seconds)."
            },

            // Per-action error domains - all 22 actions
            {
                "keyPattern": "feature\\.data\\.ext\\.(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_permissions|clear_visited_links|clear_recently_closed|clear_last_session_state|reset_cookie_popup_blocked_flag|clear_autoconsent_stats|clear_visits|clear_website_data\\.clear_file_cache|clear_website_data\\.clear_device_hash_salts|clear_website_data\\.clear_remove_resource_load_statistics_database)_error\\.domain",
                "type": "string",
                "description": "Top level error domain for action failures",
                "examples": ["DataClearingWideEventError", "NSCocoaErrorDomain", "com.duckduckgo.history"]
            },

            // Per-action error codes - all 22 actions
            {
                "keyPattern": "feature\\.data\\.ext\\.(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_permissions|clear_visited_links|clear_recently_closed|clear_last_session_state|reset_cookie_popup_blocked_flag|clear_autoconsent_stats|clear_visits|clear_website_data\\.clear_file_cache|clear_website_data\\.clear_device_hash_salts|clear_website_data\\.clear_remove_resource_load_statistics_database)_error\\.code",
                "type": "integer",
                "description": "Top level error code for action failures"
            },

            // Per-action error descriptions - all 22 actions
            {
                "keyPattern": "feature\\.data\\.ext\\.(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_permissions|clear_visited_links|clear_recently_closed|clear_last_session_state|reset_cookie_popup_blocked_flag|clear_autoconsent_stats|clear_visits|clear_website_data\\.clear_file_cache|clear_website_data\\.clear_device_hash_salts|clear_website_data\\.clear_remove_resource_load_statistics_database)_error\\.description",
                "type": "string",
                "description": "Human-readable error description for action failures",
                "examples": [
                    "coordinatorNotInitialized",
                    "fileRemovalFailed",
                    "databaseSaveFailed",
                    "historyNotLoaded",
                    "directoryCreationFailed",
                    "fileMoveOperationFailed",
                    "databaseOpenFailed"
                ]
            },

            // Per-action underlying error domains - all 22 actions
            {
                "keyPattern": "feature\\.data\\.ext\\.(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_permissions|clear_visited_links|clear_recently_closed|clear_last_session_state|reset_cookie_popup_blocked_flag|clear_autoconsent_stats|clear_visits|clear_website_data\\.clear_file_cache|clear_website_data\\.clear_device_hash_salts|clear_website_data\\.clear_remove_resource_load_statistics_database)_error\\.underlying_domain[0-9]?",
                "type": "string",
                "description": "Underlying error domain for action failures",
                "examples": ["NSPOSIXErrorDomain", "NSURLErrorDomain", "SQLite.Result"]
            },

            // Per-action underlying error codes - all 22 actions
            {
                "keyPattern": "feature\\.data\\.ext\\.(clear_tabs|clear_website_data\\.clear_safely_removable_website_data|clear_website_data\\.clear_fireproofable_data_for_nonFireproof_domains|clear_website_data\\.clear_cookies_for_nonFireproofed_domains|clear_all_history|clear_aiChat_history|clear_autoconsent_management_cache|clear_favicon_cache|cancel_all_downloads|clear_bookmark_database|forget_text_zoom|clear_privacy_stats|clear_permissions|clear_visited_links|clear_recently_closed|clear_last_session_state|reset_cookie_popup_blocked_flag|clear_autoconsent_stats|clear_visits|clear_website_data\\.clear_file_cache|clear_website_data\\.clear_device_hash_salts|clear_website_data\\.clear_remove_resource_load_statistics_database)_error\\.underlying_code[0-9]?",
                "type": "integer",
                "description": "Underlying error code for action failures"
            },
            {
                "key": "context.name",
                "type": "string",
                "description": "Context name for the flow",
                "enum": ["funnel_default_macos"]
            }
        ]
    }
}
