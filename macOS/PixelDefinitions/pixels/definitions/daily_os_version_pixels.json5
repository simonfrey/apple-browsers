// Daily OS version tracking pixels
{
    "m_mac_daily-os-version-counter": {
        "description": "Daily pixel reporting the macOS version and hardware upgrade capability",
        "owners": ["tomasstrba"],
        "privacyReview": [
            "https://app.asana.com/1/137249556945/project/69071770703008/task/1205328336555235",
            "https://app.asana.com/1/137249556945/task/1213214696334976"
        ],
        "triggers": ["scheduled"],
        "parameters": [
            {
                "key": "osMajorVersion",
                "type": "string",
                "description": "Current macOS major version",
                "pattern": "^[0-9]{1,2}$"
            },
            {
                "key": "can_update",
                "type": "string",
                "description": "Hardware upgrade capability",
                "enum": ["yes", "no", "unknown"]
            },
            {
                "key": "maxSupportedOS",
                "type": "string",
                "description": "Maximum supported macOS major version for the hardware",
                "pattern": "^([0-9]{1,2}|latest)$"
            },
            "appVersion",
            "pixelSource"
        ]
    }
}
