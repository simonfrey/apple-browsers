// WebContent process memory usage threshold pixels
// Fired daily when total WebContent process memory enters specific buckets
{
    "m_mac_memory_usage_webview_less_512": {
        "description": "Fired daily when total WebContent process memory is less than 512MB",
        "owners": ["jotaemepereira"],
        "triggers": ["other"],
        "suffixes": ["daily"],
        "parameters": [
            "appVersion",
            "pixelSource",
            {
                "key": "uptime",
                "type": "integer",
                "description": "Minutes elapsed since app launch (raw value, not bucketed)"
            }
        ]
    },
